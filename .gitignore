# ============================================================
# Editors & IDEs
# ============================================================

# CLion / IntelliJ IDEA
.idea/

# Visual Studio / VS Code local settings
.vs/
*.user
*.suo
.vscode/settings.json
.vscode/launch.json
.vscode/c_cpp_properties.json

# Vim
.cache/
.vimrc

# ============================================================
# Build artefacts
# ============================================================

# Generic CMake out-of-source build dirs
build/
out/
cmake-build-*/

# Generated by cmake --install or CPack
_CPack_Packages/
*.deb
*.rpm
*.tar.gz
*.zip

# Ninja / Make generated files that leak into the source tree
compile_commands.json
CMakeCache.txt
cmake_install.cmake
install_manifest.txt

# Test output
Testing/
CTestTestfile.cmake

# Coverage reports
*.lcov
coverage/

# Doxygen output
docs/doxygen/

# ============================================================
# Conan
# ============================================================

# Generated by `conan install` — not project source
ConanPresets.json
conan-cache/
.conan2/

# ============================================================
# Python (scripts/ folder)
# ============================================================
__pycache__/
*.py[cod]
*.pyo

# ============================================================
# Compiler / toolchain artefacts
# ============================================================

# Object files, archives, shared libs
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.pdb
*.ilk
*.exp

# Clang time-trace
*.json.gz
*.time-trace

# ccache / sccache
.ccache/

# ARM toolchain download (fetched in conan build step)
arm-gnu-toolchain-*/

# ============================================================
# User-specific CMake overrides (intentionally not shared)
# ============================================================
CMakeUserPresets.json
