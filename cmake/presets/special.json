      "cacheVariables": {
        "CPP_STARTER_USE_EMBEDDED_TOOLCHAIN": "ON",
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_SYSTEM_NAME": "Linux",
        "CMAKE_SYSTEM_PROCESSOR": "armv7l",
        "CMAKE_TRY_COMPILE_TARGET_TYPE": "STATIC_LIBRARY",
        "CMAKE_CROSSCOMPILING": "TRUE"
      }
    },
